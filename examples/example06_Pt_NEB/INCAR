System = Pt

! Ionic relaxation
NSW    = 100     # Max number of NEB optimizer steps
EDIFFG = -0.01   # Convergence criterion: max ionic force (eV/Å)
IBRION = 1       # Optimizer: LBFGS (mapped to MDMin for NEB)
POTIM  = 0.8     # Optimizer step width (ignored by vasp-mace for NEB)
ISIF   = 2       # Fixed cell, ions free

! NEB
IMAGES = 3       # Number of intermediate images
SPRING = -5      # Spring constant (eV/Å²); negative = NEB convention
