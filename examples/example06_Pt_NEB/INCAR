System = Pt

! Ionic relaxation
NSW = 100                    # Max number of ionic steps
EDIFFG = -0.01               # Break condition for ionic relaxation
IBRION = 1                   # Quasi-Newton algorithm
POTIM = 0.8                  # Step width
ISIF = 2                     # Cell shape and volume fixed, ions free

! NEB
IMAGES = 3                   # 3 intermediate geometries for the NEB
SPRING = -5                  # Spring constant (eV/Å²)
